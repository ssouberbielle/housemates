# HOUSE MATES — Template de variables de entorno
# Copiar a .env.local y completar con valores reales.
# Ver docs/CREDENTIALS.md para instrucciones de seguridad y cómo obtener cada valor.
# NUNCA commitear .env.local — está en .gitignore.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=              # server only — nunca al cliente

# --- Gate ---
# Password universal del gate. Rotable desde Vercel env vars (o desde /admin/config cuando esté implementado).
GATE_PASSWORD=cambiame
# Secret para firmar la cookie hm_access. Generar con: openssl rand -base64 32
# Mínimo 32 chars. Valor diferente por entorno (dev, preview, prod).
GATE_COOKIE_SECRET=

# --- QR ---
# Secret para el HMAC de los tokens QR. Generar con: openssl rand -base64 32
QR_HMAC_SECRET=

# --- Mercado Pago ---
MP_PUBLIC_KEY=                          # client OK — identifica la app
MP_ACCESS_TOKEN=                        # server only
MP_WEBHOOK_SECRET=                      # server only — valida x-signature

# --- Resend ---
RESEND_API_KEY=                         # server only
RESEND_FROM=HOUSE MATES <hola@housemates.com>

# --- Cron ---
# Protege /api/cron/* de llamadas externas. Generar con: openssl rand -base64 32
CRON_SECRET=

# --- Sentry (opcional hasta prod) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=                      # build only — sube source maps

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://admin.localhost:3000
NODE_ENV=development
