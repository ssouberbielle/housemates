# --- Gate (feature actual) ---
# Password universal del gate. Rotable desde Vercel env vars.
GATE_PASSWORD=cambiame

# Secret para firmar la cookie de sesión del gate. Generar con:
#   openssl rand -base64 32
# Debe tener ≥32 caracteres. Único por entorno (dev, preview, production).
GATE_COOKIE_SECRET=generar_con_openssl_rand_base64_32

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NOTA: El resto de las vars (Supabase, Mercado Pago, Resend, etc.) se agregan
# en features siguientes. Ver docs/EXTERNAL_SERVICES.md para el listado completo.
